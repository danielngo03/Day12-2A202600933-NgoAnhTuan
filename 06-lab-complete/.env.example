# Copy thành .env.local và điền giá trị thật
# ❌ KHÔNG commit file .env.local lên Git

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# App
APP_NAME=AI Agent
APP_VERSION=1.0.0

# LLM
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Security — BAT BUOC thay trong production
AGENT_API_KEY=dev-key-change-me-in-production

# Rate & Budget
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_WINDOW_SECONDS=60
MONTHLY_BUDGET_USD=10.0
ESTIMATED_REQUEST_COST_USD=0.001

# Storage
REDIS_URL=redis://localhost:6379/0
HISTORY_TTL_SECONDS=2592000
MAX_HISTORY_MESSAGES=20

# CORS
ALLOWED_ORIGINS=http://localhost:3000
